#!/bin/bash

set -e

while [ $# -gt 0 ]; do
  case "$1" in
    --domain)    DOMAIN="$2"; shift 2 ;;
    --zone-id)   ZONE_ID="$2"; shift 2 ;;
    --record-id) RECORD_ID="$2"; shift 2 ;;
    --token)     TOKEN_ARG="$2"; shift 2 ;;
    *) echo "unknown option: $1"; exit 1 ;;
  esac
done

[ -z $CLOUDFLARE_TOKEN ] && [ -f ~/.config/ddns-by-cloudflare/env ] && source ~/.config/ddns-by-cloudflare/env
[ -z $CLOUDFLARE_TOKEN ] && CLOUDFLARE_TOKEN=$TOKEN_ARG

if [ -z "$DOMAIN" ] || [ -z "$ZONE_ID" ] || [ -z "$RECORD_ID" ] || [ -z "$CLOUDFLARE_TOKEN" ]; then
  echo "Usage: ddns-by-cloudflare-wan --domain <domain> --zone-id <id> --record-id <id> [--token <t>]"
  exit 1
fi

IP=$(myip)
C_IP=$(drill $DOMAIN | grep "^$DOMAIN" | awk '{print $5}')

[ "$IP" = "$C_IP" ] && exit 0
[ -z "$IP" ] && exit 0

curl -s -X PUT "https://api.cloudflare.com/client/v4/zones/${ZONE_ID}/dns_records/${RECORD_ID}" \
     -H "Authorization: Bearer ${CLOUDFLARE_TOKEN}" \
     -H "Content-Type: application/json" \
     --data "{\"type\":\"A\",\"name\":\"${DOMAIN}\",\"content\":\"${IP}\",\"proxied\":false}"

# vim: set ft=sh:
