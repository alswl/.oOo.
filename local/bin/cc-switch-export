#!/usr/bin/env python3
"""
Export Claude Code configs from cc-switch.db to profiles directory.

Each profile contains complete config (COMMON_CONFIG merged with provider overrides).

Usage:
    cc-switch-export [db_path] [output_dir]

Defaults:
    db_path:    ~/.cc-switch/cc-switch.db
    output_dir: ~/.claude/profiles/
"""

import json
import os
import re
import sqlite3
import sys
from pathlib import Path
from typing import Optional


# Standard hooks configuration
STANDARD_HOOKS = {
    "PostToolUse": [{"hooks": [{"command": '/opt/homebrew/bin/node "$HOME/.confirmo/hooks/confirmo-hook.js"', "timeout": 5, "type": "command"}], "matcher": ""}],
    "PreToolUse": [{"hooks": [{"command": '/opt/homebrew/bin/node "$HOME/.confirmo/hooks/confirmo-hook.js"', "timeout": 5, "type": "command"}], "matcher": ""}],
    "SessionEnd": [{"hooks": [{"command": '/opt/homebrew/bin/node "$HOME/.confirmo/hooks/confirmo-hook.js"', "timeout": 5, "type": "command"}], "matcher": ""}],
    "SessionStart": [{"hooks": [{"command": '/opt/homebrew/bin/node "$HOME/.confirmo/hooks/confirmo-hook.js"', "timeout": 5, "type": "command"}], "matcher": ""}],
    "Stop": [{"hooks": [{"command": '/opt/homebrew/bin/node "$HOME/.confirmo/hooks/confirmo-hook.js"', "timeout": 5, "type": "command"}], "matcher": ""}],
    "UserPromptSubmit": [{"hooks": [{"command": '/opt/homebrew/bin/node "$HOME/.confirmo/hooks/confirmo-hook.js"', "timeout": 5, "type": "command"}], "matcher": ""}],
}

# Common config template (includes HUD statusLine)
COMMON_CONFIG = {
    "hooks": STANDARD_HOOKS,
    "primaryApiKey": "api",
    "skipWebFetchPreflight": True,
    "statusLine": {
        "command": 'bash -c \'$HOME/.bun/bin/bun "$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)src/index.ts"\'',
        "type": "command"
    }
}


def slugify(name: str) -> str:
    """Convert name to safe filename."""
    slug = re.sub(r'[^a-z0-9]+', '-', name.lower())
    slug = slug.strip('-')
    return slug or 'config'


def format_json(data: dict) -> str:
    """Format JSON output with trailing newline."""
    return json.dumps(data, indent=2, ensure_ascii=False) + '\n'


def merge_config(full_config: dict) -> dict:
    """Merge COMMON_CONFIG with provider config."""
    merged = COMMON_CONFIG.copy()
    # Deep copy hooks to avoid modifying original
    merged["hooks"] = json.loads(json.dumps(COMMON_CONFIG["hooks"]))

    # Merge provider config (override same keys)
    for key, value in full_config.items():
        if key in ('env', 'enabledPlugins'):
            merged[key] = value

    return merged


def export_config(db_path: Path, output_dir: Path) -> int:
    """Export configs, return file count."""

    if not db_path.exists():
        print(f"error: database not found: {db_path}", file=sys.stderr)
        return 0

    output_dir.mkdir(parents=True, exist_ok=True)

    print(f"Exporting from {db_path}")
    print(f"           to {output_dir}")
    print()

    count = 0

    with sqlite3.connect(db_path) as conn:
        conn.row_factory = sqlite3.Row

        cursor = conn.execute("""
            SELECT id, name, settings_config, is_current, sort_index
            FROM providers
            WHERE app_type = 'claude'
            ORDER BY sort_index, name
        """)

        providers = cursor.fetchall()
        print(f"Found {len(providers)} profiles")

        for provider in providers:
            name = provider['name']
            settings_json = provider['settings_config']
            is_current = provider['is_current']

            if not settings_json:
                continue

            try:
                full_config = json.loads(settings_json)
            except json.JSONDecodeError as e:
                print(f"  skipping {name}: invalid JSON ({e})")
                continue

            # Merge: COMMON_CONFIG + provider overrides
            merged_config = merge_config(full_config)

            filename = f"{slugify(name)}.json"
            output_file = output_dir / filename

            output_file.write_text(format_json(merged_config))

            marker = " *" if is_current else ""
            print(f"  {filename}{marker}")
            count += 1

    print()
    print(f"Exported {count} profiles")
    print()
    print("Usage:")
    print("  claude-<profile>              # use alias")
    print(f"  claude --settings {output_dir}/<name>.json")

    return count


def main() -> int:
    """Main entry point."""
    default_db = Path.home() / '.cc-switch' / 'cc-switch.db'
    default_output = Path.home() / '.claude' / 'profiles'

    db_path = Path(sys.argv[1]) if len(sys.argv) > 1 else default_db
    output_dir = Path(sys.argv[2]) if len(sys.argv) > 2 else default_output

    count = export_config(db_path, output_dir)
    return 0 if count > 0 else 1


if __name__ == '__main__':
    sys.exit(main())